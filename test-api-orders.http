#     "paymentId": "pay_123456789",
#     "paymentMethod": "credit_card",
#     "paidAt": "2024-02-08T11:00:00Z"
#   }
# }

### ============================================
### 5. CANCELAR PEDIDO
### ============================================

### Cancelar pedido
POST {{baseUrl}}/orders/uuid-do-pedido/cancel
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "reason": "Cliente solicitou cancelamento"
}

### Resposta esperada:
# {
#   "status": "success",
#   "data": {
#     "id": "uuid",
#     "orderNumber": "ORD-ABC123-XYZ",
#     "status": "cancelled",
#     "cancellationReason": "Cliente solicitou cancelamento",
#     "cancelledAt": "2024-02-08T12:00:00Z"
#   }
# }

