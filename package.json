{
  "name": "impakt-backend",
  "version": "1.0.0",
  "description": "IMPAKT - Impulsionando Mercados com Pagamentos Automáticos, Komissões e Transações",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "db:setup": "node src/scripts/setupDatabase.js",
    "db:seed": "node src/scripts/seedDatabase.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js --selectProjects unit --coverage",
    "test:e2e": "node --experimental-vm-modules node_modules/jest/bin/jest.js --selectProjects e2e --runInBand",
    "test:split": "node --experimental-vm-modules node_modules/jest/bin/jest.js CommissionCalculator --verbose",
    "test:escrow": "node --experimental-vm-modules node_modules/jest/bin/jest.js escrow --verbose",
    "test:affiliate": "node --experimental-vm-modules node_modules/jest/bin/jest.js AffiliateChain --verbose",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watchAll --selectProjects unit",
    "test:ci": "node --experimental-vm-modules node_modules/jest/bin/jest.js --ci --coverage --runInBand",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage --coverageReporters=text-summary"
  },
  "keywords": [
    "marketplace",
    "afiliados",
    "split-payment",
    "escrow"
  ],
  "author": "IMPAKT Team",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.16",
    "pg": "^8.13.1",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "jest": "^29.7.0",
    "jest-serial-runner": "^1.2.2",
    "supertest": "^6.3.0"
  }
}