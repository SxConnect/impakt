# ============================================================
# IMPAKT - Configurações de Ambiente
# ============================================================

# Servidor
NODE_ENV=development
PORT=3000
API_URL=http://localhost:3000

# Banco de Dados PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=impakt
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui
DB_SSL=false

# JWT
JWT_SECRET=sua_chave_secreta_super_segura_aqui_min_32_caracteres
JWT_EXPIRES_IN=7d

# E-mail (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu_email@gmail.com
SMTP_PASS=sua_senha_app
EMAIL_FROM=IMPAKT <noreply@impakt.com.br>

# Gateway de Pagamento
# Escolha: pagarme, stripe ou asaas
PAYMENT_PROVIDER=pagarme

# Pagar.me
PAGARME_API_KEY=sk_test_sua_api_key_aqui
PAGARME_API_URL=https://api.pagar.me/core/v5
PAGARME_WEBHOOK_SECRET=sua_webhook_secret_aqui

# Stripe
STRIPE_API_KEY=sk_test_sua_api_key_aqui
STRIPE_API_URL=https://api.stripe.com/v1
STRIPE_WEBHOOK_SECRET=whsec_sua_webhook_secret_aqui

# Asaas
ASAAS_API_KEY=$aact_sua_api_key_aqui
ASAAS_API_URL=https://www.asaas.com/api/v3
ASAAS_WEBHOOK_SECRET=sua_webhook_secret_aqui

# Storage (AWS S3 ou Cloudflare R2)
STORAGE_PROVIDER=s3
AWS_ACCESS_KEY_ID=sua_access_key
AWS_SECRET_ACCESS_KEY=sua_secret_key
AWS_REGION=us-east-1
AWS_BUCKET_NAME=impakt-media

# Plataforma
PLATFORM_FEE_PERCENT=1.00
ESCROW_DAYS=7
MIN_WITHDRAWAL_CENTS=5000

# Frontend URL (para links em e-mails)
FRONTEND_URL=https://impakt.com.br
APP_URL=http://localhost:3000

# WhatsApp
# Escolha: whatsapp-business, sxconnect ou manual
WHATSAPP_PROVIDER=manual
WHATSAPP_API_URL=https://graph.facebook.com/v17.0
WHATSAPP_API_KEY=sua_api_key_aqui
ADMIN_WHATSAPP=5511999999999
