### ============================================
### IMPAKT - Testes de API - Pagamentos
### ============================================

@baseUrl = http://localhost:3000/api
@token = seu_token_jwt_aqui
@orderId = uuid-do-pedido

### ============================================
### 1. PROCESSAR PAGAMENTO - CARTÃO DE CRÉDITO
### ============================================

### Pagar.me - Cartão de Crédito
POST {{baseUrl}}/payments
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "orderId": "{{orderId}}",
  "provider": "pagarme",
  "method": "credit_card",
  "paymentData": {
    "card": {
      "number": "4111111111111111",
      "holder_name": "João Silva",
      "exp_month": 12,
      "exp_year": 2025,
      "cvv": "123"
    },
    "cardBrand": "visa",
    "cardLastDigits": "1111",
    "installments": 1,
    "metadata": {
      "ip": "192.168.1.1",
      "user_agent": "Mozilla/5.0"
    }
  }
}

### Stripe - Cartão de Crédito
POST {{baseUrl}}/payments
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "orderId": "{{orderId}}",
  "provider": "stripe",
  "method": "credit_card",
  "paymentData": {
    "paymentMethodId": "pm_card_visa",
    "cardBrand": "visa",
    "cardLastDigits": "4242",
    "installments": 1
  }
}

### Asaas - Cartão de Crédito
POST {{baseUrl}}/payments
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "orderId": "{{orderId}}",
  "provider": "asaas",
  "method": "credit_card",
  "paymentData": {
    "card": {
      "holderName": "João Silva",
      "number": "5162306219378829",
      "expiryMonth": "12",
      "expiryYear": "2025",
      "ccv": "123"
    },
    "cardBrand": "mastercard",
    "cardLastDigits": "8829",
    "installments": 3
  }
}

