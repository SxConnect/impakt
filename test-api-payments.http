  "provider": "pagarme",
  "method": "boleto",
  "paymentData": {
    "dueDate": "2024-12-31"
  }
}

### Asaas - Boleto
POST {{baseUrl}}/payments
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "orderId": "{{orderId}}",
  "provider": "asaas",
  "method": "boleto",
  "paymentData": {
    "dueDate": "2024-12-31"
  }
}

### ============================================
### 3. PROCESSAR PAGAMENTO - PIX
### ============================================

### Pagar.me - PIX
POST {{baseUrl}}/payments
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "orderId": "{{orderId}}",
  "provider": "pagarme",
  "method": "pix",
  "paymentData": {
    "expiresIn": 3600
  }
}

### Stripe - PIX
POST {{baseUrl}}/payments
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "orderId": "{{orderId}}",
  "provider": "stripe",
  "method": "pix",
  "paymentData": {}
}

### Asaas - PIX
POST {{baseUrl}}/payments
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "orderId": "{{orderId}}",
  "provider": "asaas",
  "method": "pix",
  "paymentData": {}
}

### ============================================
### 4. OBTER DETALHES DO PAGAMENTO
### ============================================

### Obter pagamento por ID
GET {{baseUrl}}/payments/uuid-do-pagamento
Authorization: Bearer {{token}}

### Resposta esperada:
# {
#   "status": "success",
#   "data": {
#     "id": "uuid",
#     "orderId": "uuid",
#     "provider": "pagarme",
#     "providerPaymentId": "pay_123456",
#     "method": "credit_card",
#     "amountCents": 19900,
#     "status": "paid",
