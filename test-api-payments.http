#     "cardBrand": "visa",
#     "cardLastDigits": "1111",
#     "paidAt": "2024-02-08T11:00:00Z",
#     "createdAt": "2024-02-08T10:30:00Z"
#   }
# }

### ============================================
### 5. REEMBOLSAR PAGAMENTO
### ============================================

### Reembolsar pagamento (admin ou vendedor)
POST {{baseUrl}}/payments/uuid-do-pagamento/refund
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "reason": "Cliente solicitou reembolso"
}

### Resposta esperada:
# {
#   "status": "success",
#   "data": {
#     "id": "uuid",
#     "orderId": "uuid",
#     "status": "refunded",
#     "refundReason": "Cliente solicitou reembolso",
#     "refundedAt": "2024-02-08T12:00:00Z"
#   }
# }

### ============================================
### 6. WEBHOOKS (Endpoints Públicos)
### ============================================

### Webhook Pagar.me
POST {{baseUrl}}/payments/webhook/pagarme
Content-Type: application/json
X-Hub-Signature: sha256=...

{
  "id": "hook_123",
  "type": "payment.paid",
  "data": {
    "id": "pay_123456",
    "status": "paid",
    "amount": 19900
  }
}

### Webhook Stripe
POST {{baseUrl}}/payments/webhook/stripe
Content-Type: application/json
Stripe-Signature: t=...,v1=...

{
  "id": "evt_123",
  "type": "payment_intent.succeeded",
  "data": {
    "object": {
      "id": "pi_123456",
      "status": "succeeded",
      "amount": 19900
    }
  }
}

### Webhook Asaas
POST {{baseUrl}}/payments/webhook/asaas
Content-Type: application/json
Asaas-Access-Token: ...

{
  "event": "PAYMENT_CONFIRMED",
  "payment": {
    "id": "pay_123456",
    "status": "CONFIRMED",
    "value": 199.00
  }
}

### ============================================
### FLUXO COMPLETO DE PAGAMENTO
### ============================================

### 1. Cliente cria pedido
POST {{baseUrl}}/orders
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "productId": "uuid-do-produto",
  "quantity": 1,
  "affiliateLinkCode": "ABC12345"
}

### 2. Sistema retorna pedido com ID
### Guardar orderId para próximo passo

### 3. Cliente escolhe método de pagamento e processa
POST {{baseUrl}}/payments
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "orderId": "uuid-do-pedido",
  "provider": "pagarme",
  "method": "credit_card",
  "paymentData": {
    "card": {
      "number": "4111111111111111",
      "holder_name": "João Silva",
      "exp_month": 12,
      "exp_year": 2025,
      "cvv": "123"
    },
    "cardBrand": "visa",
    "cardLastDigits": "1111",
    "installments": 1
  }
}

### 4. Se cartão: pagamento confirmado imediatamente
### Se boleto/PIX: aguarda webhook de confirmação

### 5. Webhook confirma pagamento (assíncrono)
### Sistema atualiza pedido e comissões automaticamente

### 6. Cliente consulta pagamento
GET {{baseUrl}}/payments/uuid-do-pagamento
Authorization: Bearer {{token}}

### 7. Vendedor consulta pedido
GET {{baseUrl}}/orders/uuid-do-pedido
Authorization: Bearer {{token-vendedor}}

### 8. Afiliado consulta comissões
GET {{baseUrl}}/commissions
Authorization: Bearer {{token-afiliado}}

### ============================================
### TROCAR DE GATEWAY
### ============================================

### Usar Pagar.me
POST {{baseUrl}}/payments
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "orderId": "{{orderId}}",
  "provider": "pagarme",  # ⭐ Escolhe aqui
  "method": "credit_card",
  "paymentData": { ... }
}

### Usar Stripe
POST {{baseUrl}}/payments
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "orderId": "{{orderId}}",
  "provider": "stripe",  # ⭐ Escolhe aqui
  "method": "credit_card",
  "paymentData": { ... }
}

### Usar Asaas
POST {{baseUrl}}/payments
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "orderId": "{{orderId}}",
  "provider": "asaas",  # ⭐ Escolhe aqui
  "method": "credit_card",
  "paymentData": { ... }
}

### ============================================
### NOTAS IMPORTANTES
### ============================================

# 1. PROVIDERS SUPORTADOS
#    - pagarme: Cartão, Boleto, PIX
#    - stripe: Cartão, PIX (boleto não nativo)
#    - asaas: Cartão, Boleto, PIX

# 2. MÉTODOS DE PAGAMENTO
#    - credit_card: Confirmação imediata
#    - boleto: Aguarda pagamento (webhook)
#    - pix: Aguarda pagamento (webhook)
#    - debit_card: Confirmação imediata

# 3. ARQUITETURA HEXAGONAL
#    - Trocar gateway sem afetar código
#    - Adicionar novos gateways facilmente
#    - Testar com mocks
#    - Usar múltiplos gateways simultaneamente

# 4. WEBHOOKS
#    - Endpoints públicos (sem autenticação)
#    - Validação de assinatura
#    - Processamento assíncrono
#    - Atualização automática de pedidos e comissões

# 5. REEMBOLSOS
#    - Apenas admin ou vendedor
#    - Apenas pagamentos pagos
#    - Cancela comissões automaticamente
#    - Atualiza pedido para 'refunded'

# 6. SEGURANÇA
#    - Validação de webhooks
#    - Dados de cartão não são armazenados
#    - Apenas últimos 4 dígitos salvos
#    - Tokens de pagamento do gateway

# 7. CONFIGURAÇÃO
#    - Via .env: PAYMENT_PROVIDER=pagarme
#    - Via código: provider: 'stripe'
#    - Dinâmico: baseado em regras de negócio

# 8. PARCELAMENTO
#    - Até 12x (depende do gateway)
#    - Configurável por pagamento
#    - Juros definidos pelo gateway

